{
  "name": "@freckle/react-hooks",
  "version": "1.0.0",
  "description": "React hooks used at Freckle",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc -d && node gen-flow.js",
    "dev": "watch 'yarn run build' src",
    "test": "jest",
    "test:watch": "yarn run test -- --watch",
    "check-git-clean": "./check-git-clean.sh",
    "gen-flow": "yarn run flow-copy-source --ignore '**/*.test.js' src dist",
    "format": "prettier --write 'src/**/*.ts'"
  },
  "jest": {
    "testEnvironment": "jsdom"
  },
  "repository": "git@github.com:freckle/react-hooks.git",
  "author": "Freckle",
  "license": "MIT",
  "private": true,
  "peerDependencies": {
    "react-dom": ">= 16.8.0",
    "react": ">= 16.8.0"
  },
  "devDependencies": {
    "@types/jest": "^27.4.1",
    "@types/lodash": "^4.14.180",
    "@types/react": "^18.0.9",
    "flowgen": "^1.17.0",
    "jest": "^27.5.1",
    "prettier": "^2.5.1",
    "ts-jest": "^27.1.3",
    "typescript": "^4.6.2"
  },
  "dependencies": {
    "invariant": "^2.2.4",
    "lodash": "^4.17.21",
    "react": ">= 16.8.0",
    "react-dom": "16.14.0"
  }
}
